# MayaGuard Environment Configuration
# Copy this file to .env and fill in your values

# ── LLM Inference ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# vLLM (optional, for logprob/entropy features)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
VLLM_ENABLED=false

# ── Vector Database ───────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mayaguard_core
QDRANT_API_KEY=

# ── Hallucination Detection ───────────────────────────────────
HALLUCINATION_RISK_THRESHOLD=0.6
ENTROPY_HIGH_THRESHOLD=3.5
ENTROPY_MEDIUM_THRESHOLD=2.5
FAITHFULNESS_MIN_SCORE=0.7

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
LOG_LEVEL=INFO

# ── Observability ─────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
