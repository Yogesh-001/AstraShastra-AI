# MayaGuard Environment Configuration

# ── LLM Inference (Ollama — default backend) ─────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── vLLM (GPU production serving — optional) ─────────────────────────
# Enable only if running a vLLM server (requires Linux + NVIDIA GPU)
VLLM_ENABLED=false
VLLM_BASE_URL=http://127.0.0.1:8000
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
VLLM_MAX_TOKENS=512
VLLM_TEMPERATURE=0.3

# ── Vector Database ──────────────────────────────────────────────────
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=mayaguard_core

# ── Hallucination Detection Thresholds ───────────────────────────────
HALLUCINATION_RISK_THRESHOLD=0.6
ENTROPY_HIGH_THRESHOLD=3.5
ENTROPY_MEDIUM_THRESHOLD=2.5
FAITHFULNESS_MIN_SCORE=0.7

# ── Serving API Configuration ────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8080
API_WORKERS=1
LOG_LEVEL=INFO

# ── Observability ────────────────────────────────────────────────────
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ── Fine-tuned Models (optional) ─────────────────────────────────────
# Path to LoRA adapter for DeBERTa claim verification classifier
FINETUNED_VERIFIER_PATH=
FINETUNED_VERIFIER_ENABLED=false

# Path to QLoRA adapter for hallucination-aware LLM generation
QLORA_ADAPTER_PATH=
QLORA_ADAPTER_ENABLED=false
